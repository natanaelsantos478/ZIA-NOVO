# Copie este arquivo para .env e preencha com suas credenciais
# Copy this file to .env and fill in your credentials

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...sua-chave-anonima
VITE_GEMINI_API_KEY=AIza...sua-chave-gemini

# Google OAuth (opcional — ativa Calendar, Sheets, Gmail, Docs, Slides, Contatos na ZIA)
# Crie em: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Tipo: Web application | Redirect URI: https://SEU-DOMINIO/oauth/google
VITE_GOOGLE_CLIENT_ID=SEU_CLIENT_ID.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET vai apenas no Supabase Edge Functions → Secrets (nunca no frontend)
